# ╔══════════════════════════════════════════════════════════════╗
# ║  SurfaceAlpha — Environment Variables                       ║
# ║  Copy this file to .env and fill in your values             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Data Directories ──
# Root directory for all data (raw, canonical, processed).
# Defaults to ./data if not set.
DATA_DIR=./data

# ── DoltHub ──
# Repository path on DoltHub (do not change unless using a fork)
DOLTHUB_REPO=post-no-preference/options

# DoltHub credentials (only needed for private repos or API access)
# DOLTHUB_USERNAME=
# DOLTHUB_TOKEN=

# Local path for Dolt clone (if using local clone strategy instead of API)
# DOLT_CLONE_DIR=./data/dolt_clone

# ── Experiment Tracking ──
# Weights & Biases API key (get from https://wandb.ai/authorize)
# WANDB_API_KEY=
WANDB_PROJECT=SurfaceAlpha
WANDB_ENTITY=

# Set to "offline" to log locally without syncing, or "disabled" to skip
WANDB_MODE=offline

# ── Compute ──
# CUDA device(s) for training. Examples: "0", "0,1", "cpu"
CUDA_VISIBLE_DEVICES=0

# ── Reproducibility ──
# Global random seed (overridden by config if set there)
GLOBAL_SEED=42
